<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Banco de Alimentos</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container fade-in">
        <div class="header">
            <h1>🍽️ Banco de Alimentos Comunitário</h1>
            <p>Coleta, armazenamento e distribuição de alimentos</p>
        </div>
        
        <% if (user) { %>
        <div class="nav-menu">
            <a href="/dashboard" class="<%= currentPage === 'dashboard' ? 'active' : '' %>">🏠 Dashboard</a>
            <a href="/doadores" class="<%= currentPage === 'doadores' ? 'active' : '' %>">🤝 Doadores</a>
            <a href="/alimentos" class="<%= currentPage === 'alimentos' ? 'active' : '' %>">🍎 Alimentos</a>
            <% if (user.role === 'admin') { %>
            <a href="/usuarios" class="<%= currentPage === 'usuarios' ? 'active' : '' %>">👥 Usuários</a>
            <% } %>
            <a href="/perfil" class="<%= currentPage === 'perfil' ? 'active' : '' %>">👤 Perfil</a>
            <a href="/logout" style="margin-left: auto;">🚪 Sair</a>
        </div>
        <% } %>
        
        <div class="content">
            <%- body %>
        </div>
    </div>
</body>
</html> 